[core]
  editor = nvim
[user]
  name = Teyler Halama
  email = teyler@hey.com
  signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIMAg0bo8XRuPNC6vvtTWhiFBr8do+wCO6k4XRkRCDsgf

# For this section, use the "Setup Signing" button on the 1Pass SSH Key record
[gpg]
  format = ssh
[gpg "ssh"]
  allowedSignersFile = ~/.config/git/allowed_signers
  program = ~/.config/git/op-ssh-sign
[commit]
  gpgsign = true
[tag]
  gpgsign = true
[branch]
    sort = -committerdate
[diff]
    ignoreWhitespace = true
[color]
    ui = auto
